#!/usr/bin/env bash
# Enforce Conventional Commits (https://www.conventionalcommits.org/en/v1.0.0/).
# Installed via `mise run setup` (sets core.hooksPath to .githooks).
set -euo pipefail

MSG_FILE="$1"
# First non-comment, non-empty line is the header.
HEADER="$(grep -v '^#' "$MSG_FILE" | sed '/^[[:space:]]*$/d' | head -n1 || true)"

# Allow merge/revert/fixup/squash commits through untouched.
if [[ "$HEADER" =~ ^(Merge|Revert|fixup!|squash!) ]]; then
    exit 0
fi

# type(optional scope)(optional !): subject
PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/ -]+\))?(!)?: .+'

if [[ ! "$HEADER" =~ $PATTERN ]]; then
    cat >&2 <<'EOF'
✗ Commit message is not a Conventional Commit.

  Format:  <type>[optional scope][!]: <description>
  Example: feat(hotkeys): support letter keys
           fix: don't crash when config is empty
           docs(readme): clarify install steps

  Types: feat fix docs style refactor perf test build ci chore revert
  Breaking change: add "!" after type/scope, e.g. feat!: drop JSON config

See https://www.conventionalcommits.org/en/v1.0.0/
EOF
    exit 1
fi
